# Housr Analytics Environment Variables Template
# Copy this to a file named '.env.local' for local development.
# Configure these variables in your Vercel Dashboard for deployment.

# ==========================================
# Google Sheets API configuration
# ==========================================
# The ID of your source Google Sheet (copied from Code.gs)
SOURCE_SPREADSHEET_ID=1kz1icd2PaPM9qWhCy13tUOHhTKANwhlP1TpTEDsxrYQ

# Service Account credentials for reading/writing the sheet.
# Extract the client email and private key from your Google Cloud service account JSON key file.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
# IMPORTANT: The private key must include the begin/end headers and escape any newlines as \n
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKeyHere\n-----END PRIVATE KEY-----\n"

# ==========================================
# Authentication & Access Control (NextAuth)
# ==========================================
# A random 32-character string to encrypt sessions. You can generate one using: openssl rand -base64 32
NEXTAUTH_SECRET=generate-a-secure-secret-key-here
# For local development, use http://localhost:3000. On Vercel, this is automatically set.
NEXTAUTH_URL=http://localhost:3000

# Google OAuth 2.0 Credentials (created in Google Cloud Console Credentials page)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-oauth-client-secret

# Admin email allowlist (comma-separated list of emails allowed to view admin pages)
ADMIN_EMAILS=niranchan@housr.in

# ==========================================
# Vercel Cron Security
# ==========================================
# Secret to secure the cron trigger API. Copy the CRON_SECRET value from Vercel's environment variables.
CRON_SECRET=your-vercel-cron-secret-here
